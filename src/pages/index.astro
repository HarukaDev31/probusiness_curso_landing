---
import campaignsData from "../data/campaigns.json";

const codes = campaignsData.campaigns.map((c) => c.codigo);
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirigiendo…</title>
  </head>
  <body style="margin: 0; background: #000; color: #888; font-family: system-ui, sans-serif">
    <script define:vars={{ codesJson: JSON.stringify(codes), baseUrl }}>
      (function () {
        var months = [
          "ene",
          "feb",
          "mar",
          "abr",
          "may",
          "jun",
          "jul",
          "ago",
          "sep",
          "oct",
          "nov",
          "dic",
        ];
        var d = new Date();
        var list = JSON.parse(codesJson);
        var candidate = months[d.getMonth()] + d.getFullYear();
        if (list.indexOf(candidate) === -1) {
          var y = String(d.getFullYear());
          var sameYear = list.filter(function (c) {
            return c.slice(-4) === y;
          });
          candidate = sameYear.length ? sameYear[0] : list[list.length - 1];
        }
        var base = baseUrl || "/";
        var target = base + candidate + "/";
        target = target.replace(/([^:]\/)\/+/g, "$1");
        window.location.replace(target);
      })();
    </script>
    <noscript>
      <p style="padding: 24px">Activa JavaScript para entrar a la landing con la campaña del mes actual.</p>
    </noscript>
  </body>
</html>
