---
import Layout from "../layouts/Layout.astro";
import CourseBenefits from "../components/CourseBenefits.astro";
import CourseSyllabus from "../components/CourseSyllabus.astro";
import SupportBenefitsGrid from "../components/SupportBenefitsGrid.astro";
import SuccessCasesHeader from "../components/SuccessCasesHeader.astro";
import SuccessCasesCarousel from "../components/SuccessCasesCarousel.astro";
import InstructorsSection from "../components/InstructorsSection.astro";
import LimitedPriceOfferCard from "../components/LimitedPriceOfferCard.astro";
import LimitedPriceLeadForm from "../components/LimitedPriceLeadForm.astro";
import WhatsappDoubtSection from "../components/WhatsappDoubtSection.astro";
import FooterWave from "../components/FooterWave.astro";
import HeroIntroSection from "../components/HeroIntroSection.astro";
import CourseOverviewSection from "../components/CourseOverviewSection.astro";
---

<Layout>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Epilogue:wght@300;400;500;600&family=Sora:wght@400;600&display=swap"
    rel="stylesheet"
  />
  <!--link sora font 300 -->
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600&display=swap"
    rel="stylesheet"
  />
  <main class="hero-page">
    <HeroIntroSection />
    <CourseOverviewSection />

    <CourseBenefits />
    <CourseSyllabus />
    <SupportBenefitsGrid />

    <section class="success-section">
      <div class="success-wrap">
        <SuccessCasesHeader />
        <SuccessCasesCarousel />
      </div>
    </section>

    <InstructorsSection />

    <section class="limited-price">
      <div class="limited-wrap">
        <LimitedPriceOfferCard />
        <LimitedPriceLeadForm />
      </div>
    </section>
    <WhatsappDoubtSection />
    <FooterWave />
  </main>
</Layout>

<style>
  .hero-page {
    background: #000;
    color: #fff;
    font-family: "Epilogue", Inter, Arial, sans-serif;
  }
  .offer-bar {
    padding: 10px 16px;
    text-align: center;
    background: linear-gradient(90deg, #25cf43 0%, #32dd80 58%, #44e58f 100%);
    color: #fff;
    font-size: 12px;
  }
  .offer-bar p {
    margin: 0;
  }
  .offer-bar strong {
    font-weight: 700;
  }
  .hero-shell {
    width: min(100%, 1180px);
    margin: 0 auto;
    padding: 18px 16px 40px;
  }
  .hero-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .hero-logo {
    width: 128px;
  }
  .hero-btn-top {
    font-size: 16px;
    border-radius: 8px;
    padding: 8px 12px;
    color: #041109;
    text-decoration: none;
    background: linear-gradient(90deg, #25cf43 0%, #3be487 100%);
  }
  .hero-kicker {
    margin: 0 0 10px;
    font-size: 16px;
    color: #32dd80;
    font-family: "Sora", sans-serif;
  }
  h1 {
    margin: 0;
    font-size: clamp(42px, 12vw, 64px);
    line-height: 0.95;
    font-weight: 300;
    letter-spacing: -0.03em;
  }
  h1 span {
    color: #32dd80;
  }
  .hero-desc {
    margin: 16px 0 0;
    font-size: 18px;
    max-width: 620px;
  }
  .course-overview {
    background: #000;
    color: #fff;
    padding: 30px 12px 56px;
  }
  .course-kicker {
    margin: 0 0 6px;
    text-align: center;
    font-size: 16px;
  }
  .course-title {
    margin: 0 0 22px;
    text-align: center;
    font-size: clamp(46px, 12vw, 64px);
    line-height: 0.95;
    font-weight: 300;
  }
  .course-title span {
    color: #32dd80;
  }
  .course-video-card {
    width: min(100%, 1180px);
    margin: 0 auto;
    border-radius: 18px;
    background: #0f0f0f;
    min-height: 220px;
    position: relative;
  }
  .course-play {
    position: absolute;
    inset: 0;
    border: 0;
    background: transparent;
    display: grid;
    place-items: center;
  }
  .course-play-circle {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.55);
    background: rgba(255, 255, 255, 0.2);
  }
  .course-play-circle img {
    width: 34px;
    height: 34px;
  }
  .success-section {
    background: #fff;
    padding: 42px 0 50px;
    overflow: hidden;
  }
  .success-wrap {
    width: 80%;
    margin: 0 auto;
    padding: 0 16px;
    position: relative;
  }
  .limited-price {
    background: #000;
    padding: 26px 0 56px;
    color: #fff;
    overflow: hidden;
  }
  .limited-wrap {
    width: 100%;
    margin: 0 auto;
    padding: 0 14px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
  }
  @media (min-width: 981px) {
    .offer-bar {
      padding: 14px 24px;
      font-size: 16px;
    }
    .hero-shell {
      padding: 34px 48px 40px;
    }
    .hero-logo {
      width: 198px;
    }
    .hero-btn-top {
      font-size: 36px;
      border-radius: 10px;
      padding: 14px 26px;
    }
    .hero-kicker {
      font-size: 28px;
      margin-bottom: 14px;
    }
    h1 {
      font-size: clamp(60px, 6vw, 92px);
    }
    .hero-desc {
      font-size: 28px;
    }
    .course-overview {
      padding: 72px 0 96px;
    }
    .course-kicker {
      font-size: 24px;
    }
    .course-title {
      font-size: clamp(64px, 5.2vw, 92px);
      margin-bottom: 40px;
    }
    .course-video-card {
      border-radius: 24px;
      min-height: 420px;
    }
    .course-play-circle {
      width: 120px;
      height: 120px;
    }
    .course-play-circle img {
      width: 48px;
      height: 48px;
    }
    .success-section {
      padding: 88px 0 86px;
    }
    .success-wrap {
      padding: 0 36px;
    }
    .limited-price {
      padding: 42px 0 84px;
    }
    .limited-wrap {
      padding: 0 18px;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 34px;
    }
  }
</style>
