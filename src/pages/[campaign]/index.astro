---
import campaignsData from "../../data/campaigns.json";
import Layout from "../../layouts/Layout.astro";
import CourseBenefits from "../../components/CourseBenefits.astro";
import CourseSyllabus from "../../components/CourseSyllabus.astro";
import SupportBenefitsGrid from "../../components/SupportBenefitsGrid.astro";
import SuccessCasesHeader from "../../components/SuccessCasesHeader.astro";
import SuccessCasesCarousel from "../../components/SuccessCasesCarousel.astro";
import InstructorsSection from "../../components/InstructorsSection.astro";
import LimitedPriceOfferCard from "../../components/LimitedPriceOfferCard.astro";
import LimitedPriceLeadForm from "../../components/LimitedPriceLeadForm.astro";
import WhatsappDoubtSection from "../../components/WhatsappDoubtSection.astro";
import FooterWave from "../../components/FooterWave.astro";
import HeroIntroSection from "../../components/HeroIntroSection.astro";
import CourseOverviewSection from "../../components/CourseOverviewSection.astro";

export function getStaticPaths() {
  return campaignsData.campaigns.map((c) => ({
    params: { campaign: c.codigo },
  }));
}

const { campaign } = Astro.params;
const entry = campaignsData.campaigns.find((c) => c.codigo === campaign)!;
const base = import.meta.env.BASE_URL;
const graciasPath = `${base}${entry.codigo}/gracias`.replace(/([^:]\/)\/+/g, "$1");
const videoSrc = entry.ruta;
---

<Layout>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Epilogue:wght@300;400;500;600&family=Sora:wght@400;600&display=swap"
    rel="stylesheet"
  />
  <!--link sora font 300 -->
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600&display=swap"
    rel="stylesheet"
  />
  <main class="hero-page">
    <HeroIntroSection />
    <CourseOverviewSection videoSrc={videoSrc} />

    <CourseBenefits />
    <CourseSyllabus />
    <SupportBenefitsGrid />

    <section class="success-section">
      <svg
        width="576"
        height="1186"
        viewBox="0 0 576 1186"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="right-glow"
      >
        <mask
          id="mask0_2020_668"
          style="mask-type:alpha"
          maskUnits="userSpaceOnUse"
          x="142"
          y="150"
          width="953"
          height="885"
        >
          <ellipse
            cx="618.5"
            cy="592.518"
            rx="484.266"
            ry="433.014"
            transform="rotate(-156.006 618.5 592.518)"
            fill="url(#paint0_linear_2020_668)"></ellipse>
        </mask>
        <g mask="url(#mask0_2020_668)">
          <g filter="url(#filter0_f_2020_668)">
            <ellipse
              cx="380.087"
              cy="370.095"
              rx="380.087"
              ry="370.095"
              transform="matrix(-0.512211 -0.85886 0.908986 -0.416827 362.253 978.319)"
              fill="url(#paint1_linear_2020_668)"></ellipse>
          </g>
        </g>
        <defs>
          <filter
            id="filter0_f_2020_668"
            x="-4.76804"
            y="16.4704"
            width="1017.5"
            height="962.283"
            filterUnits="userSpaceOnUse"
            color-interpolation-filters="sRGB"
          >
            <feFlood flood-opacity="0" result="BackgroundImageFix"></feFlood>
            <feBlend
              mode="normal"
              in="SourceGraphic"
              in2="BackgroundImageFix"
              result="shape"></feBlend>
            <feGaussianBlur
              stdDeviation="60"
              result="effect1_foregroundBlur_2020_668"></feGaussianBlur>
          </filter>
          <linearGradient
            id="paint0_linear_2020_668"
            x1="645.509"
            y1="268.778"
            x2="606.797"
            y2="1045.41"
            gradientUnits="userSpaceOnUse"
          >
            <stop stop-color="#F585FF"></stop>
            <stop offset="0.40625" stop-color="#EF88CC" stop-opacity="0.59375"
            ></stop>
            <stop offset="1" stop-color="#D9D9D9" stop-opacity="0"></stop>
          </linearGradient>
          <linearGradient
            id="paint1_linear_2020_668"
            x1="401.286"
            y1="93.3966"
            x2="365.272"
            y2="756.878"
            gradientUnits="userSpaceOnUse"
          >
            <stop stop-color="#32DD80"></stop>
            <stop offset="1" stop-color="#32DD80" stop-opacity="0"></stop>
          </linearGradient>
        </defs>
      </svg>
      <div class="success-wrap">
        <SuccessCasesHeader />
        <SuccessCasesCarousel />
      </div>
    </section>

    <InstructorsSection />

    <section class="limited-price">
      <div class="limited-wrap">
        <LimitedPriceOfferCard />
        <LimitedPriceLeadForm
          campaignCode={entry.codigo}
          graciasPath={graciasPath}
        />
      </div>
    </section>
    <WhatsappDoubtSection />
    <FooterWave />
  </main>
  <a href="#registro" class="floating-register-btn" aria-label="Ir al formulario de registro">
    <span class="floating-register-btn-text">Registrarse<br />ahora</span>
    <span class="floating-register-btn-icon" aria-hidden="true">
      <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M2.67672e-05 13C2.67672e-05 5.82029 5.82032 0 13 0C20.1798 0 26 5.82029 26 13C26 20.1796 20.1798 26 13 26C11.0973 26 9.28727 25.5904 7.65578 24.8538C7.52766 24.7959 7.38473 24.7784 7.24703 24.8066L1.56137 25.9735C1.13331 26.0612 0.689768 25.9282 0.380784 25.6192C0.0717999 25.3102 -0.0612812 24.8667 0.0265599 24.4386L1.19337 18.753C1.22164 18.6152 1.20401 18.4724 1.14616 18.3442C0.409592 16.7127 2.67672e-05 14.9027 2.67672e-05 13ZM7.15 11.05C6.07304 11.05 5.2 11.923 5.2 13V13.013C5.2 14.0899 6.07304 14.963 7.15 14.963H7.163C8.23996 14.963 9.113 14.0899 9.113 13.013V13C9.113 11.923 8.23996 11.05 7.163 11.05H7.15ZM13 11.05C11.9231 11.05 11.05 11.923 11.05 13V13.013C11.05 14.0899 11.9231 14.963 13 14.963H13.013C14.0899 14.963 14.963 14.0899 14.963 13.013V13C14.963 11.923 14.0899 11.05 13.013 11.05H13ZM16.9 13C16.9 11.923 17.7731 11.05 18.85 11.05H18.863C19.9399 11.05 20.813 11.923 20.813 13V13.013C20.813 14.0899 19.9399 14.963 18.863 14.963H18.85C17.7731 14.963 16.9 14.0899 16.9 13.013V13Z" fill="white"/>
        </svg>
        
    </span>
  </a>
</Layout>

<style>
  .hero-page {
    background: #000;
    color: #fff;
    font-family: "Epilogue", Inter, Arial, sans-serif;
  }
  .offer-bar {
    padding: 10px 16px;
    text-align: center;
    background: linear-gradient(90deg, #25cf43 0%, #32dd80 58%, #44e58f 100%);
    color: #fff;
    font-size: 12px;
  }
  .offer-bar p {
    margin: 0;
  }
  .offer-bar strong {
    font-weight: 700;
  }
  .hero-shell {
    width: min(100%, 1180px);
    margin: 0 auto;
    padding: 18px 16px 40px;
  }
  .hero-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .hero-logo {
    width: 128px;
  }
  .hero-btn-top {
    font-size: 16px;
    border-radius: 8px;
    padding: 8px 12px;
    color: #041109;
    text-decoration: none;
    background: linear-gradient(90deg, #25cf43 0%, #3be487 100%);
  }
  .hero-kicker {
    margin: 0 0 10px;
    font-size: 16px;
    color: #32dd80;
    font-family: "Sora", sans-serif;
  }
  h1 {
    margin: 0;
    font-size: clamp(42px, 12vw, 64px);
    line-height: 0.95;
    font-weight: 300;
    letter-spacing: -0.03em;
  }
  h1 span {
    color: #32dd80;
  }
  .hero-desc {
    margin: 16px 0 0;
    font-size: 18px;
    max-width: 620px;
  }
  .course-overview {
    background: #000;
    color: #fff;
    padding: 30px 12px 56px;
  }
  .course-kicker {
    margin: 0 0 6px;
    text-align: center;
    font-size: 16px;
  }
  .course-title {
    margin: 0 0 22px;
    text-align: center;
    font-size: clamp(46px, 12vw, 64px);
    line-height: 0.95;
    font-weight: 300;
  }
  .course-title span {
    color: #32dd80;
  }
  .course-video-card {
    width: min(100%, 1180px);
    margin: 0 auto;
    border-radius: 18px;
    background: #0f0f0f;
    min-height: 220px;
    position: relative;
  }
  .course-play {
    position: absolute;
    inset: 0;
    border: 0;
    background: transparent;
    display: grid;
    place-items: center;
  }
  .course-play-circle {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.55);
    background: rgba(255, 255, 255, 0.2);
  }
  .course-play-circle img {
    width: 34px;
    height: 34px;
  }
  .success-section {
    position: relative;
    background: #fff;
    padding: 80px 0 50px;
    overflow: hidden;
  }
  .right-glow {
    position: absolute;
    right: 0;
    top: 10em;
    width: 30%;
    height: 50%;
    background: linear-gradient(
      183deg,
      #32dd80 14.44%,
      rgba(50, 221, 128, 0) 99.6%
    );
    filter: blur(60px);
  }
  .success-wrap {
    width: 80%;
    margin: 0 auto;
    padding: 0 16px;
    position: relative;
  }
  .limited-price {
    background: #000;
    padding: 26px 0 56px;
    color: #fff;
    overflow: hidden;
  }
  .limited-wrap {
    width: 100%;
    margin: 0 auto;
    padding: 0 14px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
  }
  .floating-register-btn {
    position: fixed;
    right: 14px;
    bottom: 18px;
    width: 86px;
    border-radius: 12px;
    color: #fff;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 8px 8px 10px;
    z-index: 70;
    
  }
  .floating-register-btn-text {
    text-align: center;
    font-size: 18px;
    line-height: 1.02;
    font-family: "Epilogue", sans-serif;
    font-weight: 500;
   
  }
  .floating-register-btn-icon {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    background: radial-gradient(circle at 30% 25%, #3df7a2 0%, #0edb76 56%, #09bc64 100%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 26px rgba(14, 219, 118, 0.5);
  }
  .floating-register-btn-icon svg {
    width: 36px;
    height: 36px;
  }
  @media (min-width: 981px) {
    .offer-bar {
      padding: 14px 24px;
      font-size: 16px;
    }
    .hero-shell {
      padding: 34px 48px 40px;
    }
    .hero-logo {
      width: 198px;
    }
    .hero-btn-top {
      font-size: 36px;
      border-radius: 10px;
      padding: 14px 26px;
    }
    .hero-kicker {
      font-size: 28px;
      margin-bottom: 14px;
    }
    h1 {
      font-size: clamp(60px, 6vw, 92px);
    }
    .hero-desc {
      font-size: 28px;
    }
    .course-overview {
      padding: 72px 0 96px;
    }
    .course-kicker {
      font-size: 24px;
    }
    .course-title {
      font-size: clamp(64px, 5.2vw, 92px);
      margin-bottom: 40px;
    }
    .course-video-card {
      border-radius: 24px;
      min-height: 420px;
    }
    .course-play-circle {
      width: 120px;
      height: 120px;
    }
    .course-play-circle img {
      width: 48px;
      height: 48px;
    }
    .success-section {
      padding: 88px 0 86px;
    }
    .success-wrap {
      padding: 0 36px;
    }
    .limited-price {
      padding: 42px 0 84px;
    }
    .limited-wrap {
      grid-template-columns: 0.9fr 1.1fr;
      gap: 34px;
    }
    .floating-register-btn {
      right: 20px;
      bottom: 24px;
      width: 98px;
    }
    .floating-register-btn-text {
      font-size: 20px;
    }
    .floating-register-btn-icon {
      width: 62px;
      height: 62px;
    }
  }

  @media (max-width: 980px) {
    .hero-page {
      overflow-x: hidden;
    }

    .right-glow {
      right: auto;
      left: 0;
      transform: scaleX(-1);
    }

    .success-wrap {
      width: 100%;
      max-width: 100%;
      padding-inline: clamp(12px, 4vw, 20px);
      box-sizing: border-box;
    }

    .limited-wrap {
      padding-inline: clamp(16px, 5vw, 28px);
      max-width: 100%;
      box-sizing: border-box;
    }
  }
</style>
