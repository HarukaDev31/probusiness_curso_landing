---
const apiUrl = import.meta.env.PUBLIC_LANDING_CURSO_API_URL ?? "/api/public/landing-curso/leads";
const formToken = import.meta.env.PUBLIC_LANDING_CURSO_FORM_TOKEN ?? "";

interface Props {
  /** Código de campaña (ej. mar2026), coincide con la ruta /{codigo}/ */
  campaignCode: string;
  /** Ruta de gracias para esta campaña, ej. /mar2026/gracias */
  graciasPath: string;
}

const { campaignCode, graciasPath } = Astro.props;
---

<article class="form-panel" id="registro">
  <img
    class="hourglass"
    src="https://cdn.probusiness.pe/landingcurso/figma/pricing/hourglass.webp"
    alt=""
    aria-hidden="true"
  />
  <h3>Precio por<br />tiempo<br />limitado</h3>
  <form
    class="lead-form"
    id="landing-curso-form"
    data-api-url={apiUrl}
    data-form-token={formToken}
  >
    <label
      >Nombre Completo<input name="nombre" placeholder="e.g José Gutiérrez" required /></label
    >
    <label
      >Número de WhatsApp<input name="whatsapp" placeholder="999 999 999" required /></label
    >
    <label
      >Correo electrónico<input
        name="email"
        type="email"
        placeholder="jgutierrezl@example.com"
        required
      /></label
    >
    <label
      >¿Tienes experiencia importando?
      <select name="experiencia_importando" required>
        <option value="" selected disabled>Selecciona una opción</option>
        <option value="si">Si</option>
        <option value="no">No</option>
        <option value="poca">Poca</option>
      </select>
    </label>
    <button type="submit">Inscribirme por S/ 380</button>
  </form>
  <p class="form-foot" id="landing-curso-form-feedback">
    Un asesor te contactará para confirmar tu inscripción
  </p>
</article>
<style>
  .form-panel {
    position: relative;
    height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 4em;
    gap: 1em;
    width: 80%;
    margin: 0 auto;
  }
  .form-panel h3 {
    margin: 0 0 16px;
    font-size: clamp(42px, 11vw, 60px);
    line-height: 0.9;
    font-weight: 300;
  }
  .hourglass {
    position: absolute;
    width: 210px;
    right: -50px;
    top: -22px;
    transform: rotate(-38deg);
    pointer-events: none;
  }
  .lead-form {
    display: grid;
    gap: 10px;
    max-width: 640px;
  }
  .lead-form label {
    font-size: 14px;
    display: grid;
    gap: 6px;
  }
  .lead-form input,
  .lead-form select {
    height: 52px;
    border-radius: 10px;
    border: 1px solid #000;
    background: #1a1a1a;
    color: #9c9c9c;
    font-size: 14px;
    padding: 0 14px;
  }
  .lead-form button {
    height: 52px;
    border-radius: 10px;
    border: 1px solid #000;
    background: linear-gradient(90deg, #32dd80, #6dffb0);
    color: #000;
    font-size: 20px;
    font-weight: 600;
    font-family: 'Epilogue', sans-serif;
    cursor: pointer;
  }
  .lead-form button:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .form-foot {
    margin: 12px 0 0;
    text-align: center;
    font-size: 14px;
  }

  @media (max-width: 980px) {
    .form-panel {
      height: auto;
      min-height: 0;
      width: 100%;
      max-width: 100%;
      padding: clamp(1.25rem, 5vw, 2rem);
      box-sizing: border-box;
    }
    .hourglass {
      width: min(140px, 38vw);
      right: -24px;
      top: -12px;
    }
    .lead-form {
      max-width: 100%;
    }
  }
</style>

<script
  define:vars={{
    campaignCode,
    graciasPath,
  }}
>
  const form = document.getElementById("landing-curso-form");
  const feedback = document.getElementById("landing-curso-form-feedback");

  if (form instanceof HTMLFormElement && feedback) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]');
      if (!(submitButton instanceof HTMLButtonElement)) return;

      const apiUrl = form.dataset.apiUrl;
      const formToken = form.dataset.formToken;

      if (!apiUrl) {
        feedback.textContent =
          "El formulario no esta configurado. Contacta al administrador.";
        return;
      }

      const formData = new FormData(form);
      const payload = {
        nombre: String(formData.get("nombre") ?? "").trim(),
        whatsapp: String(formData.get("whatsapp") ?? "").trim(),
        email: String(formData.get("email") ?? "").trim(),
        experiencia_importando: String(formData.get("experiencia_importando") ?? "").trim(),
        codigo_campana: campaignCode,
      };

      submitButton.disabled = true;
      feedback.textContent = "Enviando...";

      try {
        const response = await fetch(apiUrl, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            ...(formToken ? { Authorization: `Bearer ${formToken}` } : {}),
          },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          feedback.textContent =
            "No se pudo enviar tu registro. Intentalo nuevamente en unos minutos.";
          return;
        }

        sessionStorage.setItem("leadFormConfirmed", "1");
        sessionStorage.setItem("leadFormConfirmedAt", String(Date.now()));
        window.location.href = graciasPath;
      } catch (error) {
        feedback.textContent =
          "No se pudo enviar tu registro. Verifica tu conexion e intenta de nuevo.";
      } finally {
        submitButton.disabled = false;
      }
    });
  }
</script>
