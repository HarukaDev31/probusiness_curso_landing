---
function tikTokVideoId(href: string): string {
  const m = href.match(/\/video\/(\d+)/);
  return m?.[1] ?? "";
}

const cards = [
  { href: "https://www.tiktok.com/@pro_business_impo/video/7573862255759002892", tag: "CASO DE ÉXITO" },
  { href: "https://www.tiktok.com/@pro_business_impo/video/7589488343231073592", tag: "CASO DE ÉXITO" },
  { href: "https://www.tiktok.com/@pro_business_impo/video/7558631582156754187", tag: "CASO DE ÉXITO" },
  { href: "https://www.tiktok.com/@pro_business_impo/video/7621708070598626561", tag: "CASO DE ÉXITO" },
  { href: "https://www.tiktok.com/@pro_business_impo/video/7599820210345889045", tag: "CASO DE ÉXITO" },
  { href: "https://www.tiktok.com/@pro_business_impo/video/7567580877408996629", tag: "CASO DE ÉXITO" },
  { href: "https://www.tiktok.com/@pro_business_impo/video/7545278265087331592", tag: "CASO DE ÉXITO" },
];
---

<div class="success-carousel-wrap">
  <div
    class="success-carousel"
    id="success-carousel-track"
    tabindex="0"
    role="region"
    aria-label="Casos de éxito"
  >
    {cards.map((c, i) => (
      <article
        class="success-slide"
        data-success-slide
        data-success-slide-index={i}
        data-tiktok-id={tikTokVideoId(c.href)}
        data-tiktok-url={c.href}
      >
        <div class="success-card">
          <div class="success-poster">
            <img class="success-poster-img" alt="" loading="lazy" decoding="async" />
            <span class="success-play" aria-hidden="true">
              <img src="/figma/play-long.svg" alt="" />
            </span>
            <button
              type="button"
              class="success-activate"
              aria-label={`Reproducir caso de éxito ${i + 1}`}
            ></button>
          </div>
          <div class="success-embed" hidden aria-hidden="true">
            <button
              type="button"
              class="success-collapse"
              aria-label="Cerrar video y volver a la vista previa"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M18 6L6 18M6 6l12 12"></path>
              </svg>
            </button>
            <iframe
              class="success-tiktok-iframe"
              title={`TikTok — caso de éxito ${i + 1}`}
              allow="autoplay; encrypted-media; fullscreen; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>

        <div class="success-cap">
          <strong>CLIENTE TESTIMONIO</strong>
          <small>{c.tag}</small>
        </div>
      </article>
    ))}
  </div>

  <div
    class="success-dots"
    role="tablist"
    aria-label="Página del carrusel"
    id="success-carousel-dots"
  >
    {cards.map((_, i) => (
      <button
        type="button"
        class:list={['success-dot', { active: i === 0 }]}
        role="tab"
        aria-selected={i === 0}
        aria-controls="success-carousel-track"
        data-success-dot={i}
      >
        <span class="visually-hidden">Slide {i + 1}</span>
      </button>
    ))}
  </div>
</div>

<script>
  // @ts-nocheck
  (() => {
    const trackEl = document.getElementById("success-carousel-track");
    const dotsWrapEl = document.getElementById("success-carousel-dots");
    if (!(trackEl instanceof HTMLElement) || !(dotsWrapEl instanceof HTMLElement)) return;

    const slides = () => Array.from(trackEl.querySelectorAll("[data-success-slide]"));
    const dots = () => Array.from(dotsWrapEl.querySelectorAll("[data-success-dot]"));

    async function resolveTikTokThumbnailUrl(videoUrl) {
      try {
        const r = await fetch(`https://noembed.com/embed?url=${encodeURIComponent(videoUrl)}`);
        if (r.ok) {
          const d = await r.json();
          if (typeof d?.thumbnail_url === "string" && d.thumbnail_url.length > 0) {
            return d.thumbnail_url;
          }
        }
      } catch {}
      try {
        const r2 = await fetch(`https://api.microlink.io/?url=${encodeURIComponent(videoUrl)}`);
        if (r2.ok) {
          const d2 = await r2.json();
          if (typeof d2?.data?.image?.url === "string" && d2.data.image.url.length > 0) {
            return d2.data.image.url;
          }
        }
      } catch {}
      return null;
    }

    function loadPosterThumbnails() {
      slides().forEach((slide) => {
        if (!(slide instanceof HTMLElement)) return;
        const url = slide.getAttribute("data-tiktok-url");
        const img = slide.querySelector(".success-poster-img");
        if (!url || !(img instanceof HTMLImageElement)) return;
        void (async () => {
          const thumb = await resolveTikTokThumbnailUrl(url);
          if (!thumb) return;
          img.onload = () => img.classList.add("success-poster-img--ready");
          img.src = thumb;
        })();
      });
    }

    function tikTokPlayerUrl(videoId, autoplay = true) {
      const q = new URLSearchParams({
        music_info: "0",
        description: "0",
        rel: "0",
        autoplay: autoplay ? "1" : "0",
        playsinline: "1",
        muted: "0",
      });
      return `https://www.tiktok.com/player/v1/${videoId}?${q.toString()}`;
    }

    function postToTiktokPlayer(iframe, type) {
      if (!(iframe instanceof HTMLIFrameElement) || !iframe.contentWindow) return;
      try {
        iframe.contentWindow.postMessage({ type, "x-tiktok-player": true }, "*");
      } catch {}
    }

    function kickTiktokPlayback(iframe) {
      postToTiktokPlayer(iframe, "play");
      postToTiktokPlayer(iframe, "unMute");
    }

    function deactivateTiktokSlide(slide) {
      if (!(slide instanceof HTMLElement)) return;
      slide.classList.remove("success-slide--playing");
      const wrap = slide.querySelector(".success-embed");
      const iframe = slide.querySelector(".success-tiktok-iframe");
      if (wrap instanceof HTMLElement) {
        wrap.hidden = true;
        wrap.setAttribute("aria-hidden", "true");
      }
      if (iframe instanceof HTMLIFrameElement) {
        iframe.src = "about:blank";
      }
    }

    function activateTiktokSlide(slide) {
      if (!(slide instanceof HTMLElement)) return;
      const id = slide.getAttribute("data-tiktok-id");
      const wrap = slide.querySelector(".success-embed");
      const iframe = slide.querySelector(".success-tiktok-iframe");
      if (!id || !(wrap instanceof HTMLElement) || !(iframe instanceof HTMLIFrameElement)) return;

      slides().forEach((s) => {
        if (s !== slide && s instanceof HTMLElement && s.classList.contains("success-slide--playing")) {
          deactivateTiktokSlide(s);
        }
      });

      slide.classList.add("success-slide--playing");
      wrap.hidden = false;
      wrap.setAttribute("aria-hidden", "false");
      iframe.src = tikTokPlayerUrl(id, true);
      iframe.addEventListener("load", () => kickTiktokPlayback(iframe), { once: true });
      [100, 260, 700, 1400].forEach((ms) => {
        window.setTimeout(() => kickTiktokPlayback(iframe), ms);
      });
    }

    function preloadTikTokPlayerIframes() {
      slides().forEach((slide) => {
        if (!(slide instanceof HTMLElement)) return;
        const id = slide.getAttribute("data-tiktok-id");
        const iframe = slide.querySelector(".success-tiktok-iframe");
        if (!id || !(iframe instanceof HTMLIFrameElement)) return;
        if (iframe.getAttribute("src")) return;
        iframe.src = tikTokPlayerUrl(id, false);
      });
    }

    trackEl.addEventListener("click", (e) => {
      const tgt = e.target instanceof Element ? e.target : null;
      if (!tgt) return;
      const collapse = tgt.closest(".success-collapse");
      if (collapse) {
        const slide = collapse.closest("[data-success-slide]");
        if (slide && trackEl.contains(slide)) deactivateTiktokSlide(slide);
        return;
      }
      const activate = tgt.closest(".success-activate");
      if (!activate) return;
      const slide = activate.closest("[data-success-slide]");
      if (slide && trackEl.contains(slide)) activateTiktokSlide(slide);
    });

    loadPosterThumbnails();
    if (typeof requestIdleCallback !== "undefined") {
      requestIdleCallback(() => preloadTikTokPlayerIframes(), { timeout: 3000 });
    } else {
      setTimeout(preloadTikTokPlayerIframes, 700);
    }

    function activeIndex() {
      const trackRect = trackEl.getBoundingClientRect();
      const trackMid = (trackRect.left + trackRect.right) / 2;
      const list = slides();
      let best = 0;
      let bestOverlap = -1;
      let bestCenterDist = Infinity;
      for (let i = 0; i < list.length; i++) {
        const el = list[i];
        if (!(el instanceof HTMLElement)) continue;
        const er = el.getBoundingClientRect();
        const left = Math.max(er.left, trackRect.left);
        const right = Math.min(er.right, trackRect.right);
        const overlap = Math.max(0, right - left);
        const elMid = (er.left + er.right) / 2;
        const centerDist = Math.abs(elMid - trackMid);
        if (
          overlap > bestOverlap ||
          (overlap === bestOverlap && centerDist < bestCenterDist)
        ) {
          bestOverlap = overlap;
          bestCenterDist = centerDist;
          best = i;
        }
      }
      return best;
    }

    /** @param {number} i */
    function setDots(i) {
      dots().forEach((btn, j) => {
        const on = j === i;
        btn.classList.toggle("active", on);
        btn.setAttribute("aria-selected", on ? "true" : "false");
      });
    }

    /** Marca slides con `is-partial` si no caben enteros en la pista (difuminado solo ahí). */
    function updatePartialVisibility() {
      const trackRect = trackEl.getBoundingClientRect();
      slides().forEach((el) => {
        if (!(el instanceof HTMLElement)) return;
        const r = el.getBoundingClientRect();
        const fully =
          r.left >= trackRect.left - 1 &&
          r.right <= trackRect.right + 1 &&
          r.width > 0;
        el.classList.toggle("is-partial", !fully);
      });
    }

    /**
     * @param {number} i
     * @param {{ behavior?: ScrollBehavior }} [opts]
     */
    function scrollToSlide(i, opts = {}) {
      const list = slides();
      const el = list[i];
      if (!(el instanceof HTMLElement)) return;
      const centerSnap = window.matchMedia("(max-width: 980px)").matches;
      let left = el.offsetLeft;
      if (centerSnap) {
        left =
          el.offsetLeft -
          trackEl.clientWidth / 2 +
          el.offsetWidth / 2;
      }
      const behavior = opts.behavior ?? "smooth";
      trackEl.scrollTo({
        left: Math.max(0, left),
        behavior,
      });
    }

    /** @param {number} i */
    function goTo(i) {
      const list = slides();
      if (i < 0 || i >= list.length) return;
      setDots(i);
      scrollToSlide(i);
    }

    /** En móvil el carrusel inicia desde el primer slide (índice 0). */
    function applyInitialPosition() {
      const list = slides();
      if (list.length < 2) {
        sync();
        return;
      }
      const isMobile = window.matchMedia("(max-width: 980px)").matches;
      if (isMobile) {
        setDots(0);
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            scrollToSlide(0, { behavior: "auto" });
            updatePartialVisibility();
          });
        });
      } else {
        sync();
      }
    }

    let ticking = false;
    function sync() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const idx = activeIndex();
        setDots(idx);
        updatePartialVisibility();
        ticking = false;
      });
    }

    trackEl.addEventListener("scroll", sync, { passive: true });
    trackEl.addEventListener("scrollend", sync);
    window.addEventListener("resize", sync, { passive: true });

    dotsWrapEl.addEventListener("click", (e) => {
      const tgt = e.target;
      const t = tgt instanceof Element ? tgt.closest("[data-success-dot]") : null;
      if (!t) return;
      const i = Number(t.getAttribute("data-success-dot"));
      if (!Number.isNaN(i)) goTo(i);
    });

    trackEl.addEventListener("keydown", (e) => {
      const cur = activeIndex();
      const list = slides();
      if (e.key === "ArrowRight") {
        e.preventDefault();
        goTo(Math.min(cur + 1, list.length - 1));
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        goTo(Math.max(cur - 1, 0));
      }
    });

    // Drag con mouse para deslizar horizontalmente.
    let isDragging = false;
    let dragMoved = false;
    let startX = 0;
    let startScrollLeft = 0;
    const dragThreshold = 6;

    const onMouseMove = (e) => {
      if (!isDragging) return;
      const deltaX = e.clientX - startX;
      if (Math.abs(deltaX) > dragThreshold) dragMoved = true;
      trackEl.scrollLeft = startScrollLeft - deltaX;
      if (dragMoved) e.preventDefault();
    };

    const endDrag = () => {
      if (!isDragging) return;
      isDragging = false;
      trackEl.classList.remove("is-dragging");
      window.removeEventListener("mousemove", onMouseMove);
      window.removeEventListener("mouseup", endDrag);
      sync();
    };

    trackEl.addEventListener("mousedown", (e) => {
      if (e.button !== 0) return;
      isDragging = true;
      dragMoved = false;
      startX = e.clientX;
      startScrollLeft = trackEl.scrollLeft;
      trackEl.classList.add("is-dragging");
      window.addEventListener("mousemove", onMouseMove);
      window.addEventListener("mouseup", endDrag);
    });

    trackEl.addEventListener("mouseleave", endDrag);
    trackEl.addEventListener(
      "click",
      (e) => {
        if (dragMoved) {
          e.preventDefault();
          e.stopPropagation();
          dragMoved = false;
        }
      },
      true
    );

    applyInitialPosition();
  })();
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .success-carousel-wrap {
    overflow: hidden;
    /* Rompe el contenedor centrado y llega al borde del viewport (pista más “deslizable”). */
    width: 100vw;
    margin-left: calc(50% - 50vw);
    max-width: none;
  }

  .success-carousel {
    --gap: 14px;
    /* Alineado con el padding del contenido; la primera card no arranca en x=0. */
    --carousel-inset: 16px;
    margin-top: 30px;
    margin-left: var(--carousel-inset);
    display: flex;
    gap: var(--gap);
    overflow-x: auto;
    scroll-snap-type: x proximity;
    padding: 8px 0 12px;
    padding-right: var(--carousel-inset);
    scrollbar-width: none;
    -ms-overflow-style: none;
    outline: none;
    cursor: grab;
    scroll-padding-left: var(--carousel-inset);
    scroll-padding-right: var(--carousel-inset);
    box-sizing: border-box;
    width: calc(100% - var(--carousel-inset));
    /* El smooth en CSS rompe el arrastre; el salto suave va solo en scrollTo({ behavior: 'smooth' }). */
    scroll-behavior: auto;
  }

  .success-carousel::-webkit-scrollbar {
    display: none;
  }

  .success-carousel.is-dragging {
    cursor: grabbing;
    user-select: none;
    scroll-snap-type: none;
  }

  .success-carousel.is-dragging .success-card,
  .success-carousel.is-dragging .success-cap {
    transition: none;
  }

  .success-slide {
    flex: 0 0 clamp(200px, 72vw, 280px);
    width: clamp(200px, 72vw, 280px);
    min-width: clamp(200px, 72vw, 280px);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .success-card {
    width: 100%;
    aspect-ratio: 9 / 16;
    min-height: 0;
    border-radius: 12px;
    background: #2b2b2b;
    display: grid;
    place-items: center;
    border: 0;
    padding: 0;
    cursor: pointer;
    transform-origin: center center;
    transition:
      opacity 0.35s ease,
      filter 0.35s ease,
      box-shadow 0.35s ease;
    filter: none;
    opacity: 1;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.22);
    overflow: hidden;
    position: relative;
  }

  .success-poster,
  .success-embed {
    position: absolute;
    inset: 0;
  }

  .success-poster {
    background: #111;
    position: relative;
  }

  .success-poster-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .success-poster-img--ready {
    opacity: 1;
  }

  .success-activate {
    position: absolute;
    inset: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .success-embed {
    background: #000;
    z-index: 2;
  }

  .success-embed[hidden] {
    display: none;
  }

  .success-tiktok-iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    background: #000;
  }

  .success-collapse {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    cursor: pointer;
  }

  /* Solo difuminado cuando el slide no se ve completo en la pista. */
  .success-slide.is-partial .success-card {
    opacity: 0.62;
    filter: blur(4px);
    box-shadow: none;
  }

  .success-play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 74px;
    height: 74px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.35);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
    z-index: 2;
    pointer-events: none;
  }

  .success-play img {
    width: 42px;
    height: 42px;
    object-fit: contain;
    display: block;
  }

  .success-cap {
    text-align: center;
    transition: opacity 0.35s ease;
  }

  .success-slide.is-partial .success-cap {
    opacity: 0.5;
  }

  .success-cap strong {
    display: block;
    width: 214px;
    max-width: 100%;
    margin: 0 auto;
    font-size: 15px;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #111;
  }

  .success-cap small {
    display: block;
    margin-top: 3px;
    color: #32dd80;
    font-size: 9px;
    text-transform: uppercase;
  }

  .success-dots {
    margin-top: 18px;
    display: flex;
    justify-content: center;
    gap: 8px;
    height: 20px;
  }

  .success-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 0;
    padding: 0;
    background: #c7c7c7;
    cursor: pointer;
    transition:
      transform 0.4s cubic-bezier(0.25, 0.85, 0.35, 1),
      background-color 0.35s ease;
  }

  .success-dot.active {
    background: #32dd80;
    transform: scale(1.35);
  }

  @media (min-width: 901px) {
    .success-carousel {
      --carousel-inset: 36px;
      /* Base de 3 columnas; el ancho real es un poco mayor para que el 3.er card quede cortado por el borde (peek). */
      --slide-base: calc((100% - 2 * var(--gap)) / 3);
    }

    .success-slide {
      flex: 0 0 calc(var(--slide-base) * 1.09);
      width: calc(var(--slide-base) * 1.09);
      min-width: calc(var(--slide-base) * 1.09);
    }
  }

  @media (max-width: 980px) {
    /*
      1 carta centrada + ~½ + ~½ a los lados:
      2*w + 2*gap ≈ ancho útil → w = (100vw - insets - 2*gap) / 2
    */
    .success-carousel {
      --carousel-inset: clamp(12px, 4vw, 20px);
      --gap: 10px;
      --slide-w: calc(
        (100vw - 2 * var(--carousel-inset) - 2 * var(--gap)) / 2
      );
      margin-left: 0;
      margin-right: 0;
      width: 100%;
      max-width: 100%;
      scroll-snap-type: x mandatory;
      scroll-padding-left: 0;
      scroll-padding-right: 0;
      padding: 8px 0 12px;
      box-sizing: border-box;
    }

    .success-slide {
      flex: 0 0 var(--slide-w);
      width: var(--slide-w);
      min-width: var(--slide-w);
      scroll-snap-align: center;
    }

    .success-play { width: 58px; height: 58px; }

    .success-cap {
      margin-top: 8px;
      gap: 6px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .success-cap strong {
      width: min(100%, 240px);
      font-size: clamp(14px, 4vw, 17px);
      line-height: 1.2;
    }

    .success-cap small {
      font-size: clamp(10px, 2.8vw, 12px);
      margin-top: 2px;
      letter-spacing: 0.04em;
    }
    .success-dot { width: 10px; height: 10px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .success-card,
    .success-cap,
    .success-dot {
      transition: none;
    }

    .success-slide.is-partial .success-card {
      filter: none;
      opacity: 0.65;
    }

    .success-dot.active {
      transform: none;
    }
  }
</style>
