---
const cards = [
  { title: 'JHONNY — RACKS PARA TV', tag: 'CASO DE ÉXITO' },
  { title: 'CLIENTE TESTIMONIO', tag: 'CASO DE ÉXITO' },
  { title: 'CLIENTE TESTIMONIO', tag: 'CASO DE ÉXITO' },
  { title: 'JHONNY — RACKS PARA TV', tag: 'CASO DE ÉXITO' },
  { title: 'CLIENTE TESTIMONIO', tag: 'CASO DE ÉXITO' },
  { title: 'CLIENTE TESTIMONIO', tag: 'CASO DE ÉXITO' },
];
---

<div class="success-carousel-wrap">
  <div
    class="success-carousel"
    id="success-carousel-track"
    tabindex="0"
    role="region"
    aria-label="Casos de éxito"
  >
    {cards.map((c, i) => (
      <article class="success-slide" data-success-slide data-success-slide-index={i}>
        <button
          class="success-card"
          type="button"
          aria-label={`Reproducir testimonio: ${c.title}`}
        >
          <span class="success-play" aria-hidden="true">
            <img src="/figma/play-long.svg" alt="" />
          </span>
        </button>

        <div class="success-cap">
          <strong>{c.title}</strong>
          <small>{c.tag}</small>
        </div>
      </article>
    ))}
  </div>

  <div
    class="success-dots"
    role="tablist"
    aria-label="Página del carrusel"
    id="success-carousel-dots"
  >
    {cards.map((_, i) => (
      <button
        type="button"
        class:list={['success-dot', { active: i === 0 }]}
        role="tab"
        aria-selected={i === 0}
        aria-controls="success-carousel-track"
        data-success-dot={i}
      >
        <span class="visually-hidden">Slide {i + 1}</span>
      </button>
    ))}
  </div>
</div>

<script>
  // @ts-nocheck
  (() => {
    const trackEl = document.getElementById("success-carousel-track");
    const dotsWrapEl = document.getElementById("success-carousel-dots");
    if (!(trackEl instanceof HTMLElement) || !(dotsWrapEl instanceof HTMLElement)) return;

    const slides = () => Array.from(trackEl.querySelectorAll("[data-success-slide]"));
    const dots = () => Array.from(dotsWrapEl.querySelectorAll("[data-success-dot]"));

    function activeIndex() {
      const trackRect = trackEl.getBoundingClientRect();
      const trackMid = (trackRect.left + trackRect.right) / 2;
      const list = slides();
      let best = 0;
      let bestOverlap = -1;
      let bestCenterDist = Infinity;
      for (let i = 0; i < list.length; i++) {
        const el = list[i];
        if (!(el instanceof HTMLElement)) continue;
        const er = el.getBoundingClientRect();
        const left = Math.max(er.left, trackRect.left);
        const right = Math.min(er.right, trackRect.right);
        const overlap = Math.max(0, right - left);
        const elMid = (er.left + er.right) / 2;
        const centerDist = Math.abs(elMid - trackMid);
        if (
          overlap > bestOverlap ||
          (overlap === bestOverlap && centerDist < bestCenterDist)
        ) {
          bestOverlap = overlap;
          bestCenterDist = centerDist;
          best = i;
        }
      }
      return best;
    }

    /** @param {number} i */
    function setDots(i) {
      dots().forEach((btn, j) => {
        const on = j === i;
        btn.classList.toggle("active", on);
        btn.setAttribute("aria-selected", on ? "true" : "false");
      });
    }

    /** @param {number} i */
    function scrollToSlide(i) {
      const list = slides();
      const el = list[i];
      if (!(el instanceof HTMLElement)) return;
      trackEl.scrollTo({ left: el.offsetLeft, behavior: "smooth" });
    }

    /** @param {number} i */
    function goTo(i) {
      const list = slides();
      if (i < 0 || i >= list.length) return;
      setDots(i);
      scrollToSlide(i);
    }

    let ticking = false;
    function sync() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        setDots(activeIndex());
        ticking = false;
      });
    }

    trackEl.addEventListener("scroll", sync, { passive: true });
    trackEl.addEventListener("scrollend", sync);
    window.addEventListener("resize", sync, { passive: true });

    dotsWrapEl.addEventListener("click", (e) => {
      const tgt = e.target;
      const t = tgt instanceof Element ? tgt.closest("[data-success-dot]") : null;
      if (!t) return;
      const i = Number(t.getAttribute("data-success-dot"));
      if (!Number.isNaN(i)) goTo(i);
    });

    trackEl.addEventListener("keydown", (e) => {
      const cur = activeIndex();
      const list = slides();
      if (e.key === "ArrowRight") {
        e.preventDefault();
        goTo(Math.min(cur + 1, list.length - 1));
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        goTo(Math.max(cur - 1, 0));
      }
    });

    sync();
  })();
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .success-carousel-wrap {
    width: 100%;
    overflow: hidden;
  }

  .success-carousel {
    --gap: 14px;
    margin-top: 30px;
    display: flex;
    gap: var(--gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 8px 4px 12px;
    margin-inline: -8px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    outline: none;
  }

  .success-carousel::-webkit-scrollbar {
    display: none;
  }

  .success-slide {
    flex: 0 0 calc(100% - 56px);
    width: calc(100% - 56px);
    min-width: calc(100% - 56px);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .success-card {
    width: 100%;
    min-height: 380px;
    border-radius: 10px;
    background: #2b2b2b;
    display: grid;
    place-items: center;
    border: 0;
    padding: 0;
    cursor: pointer;
  }

  .success-play {
    width: 72px;
    height: 72px;
    display: grid;
    place-items: center;
  }

  .success-play img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .success-cap {
    text-align: center;
  }

  .success-cap strong {
    display: block;
    width: 214px;
    max-width: 100%;
    margin: 0 auto;
    font-size: 15px;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #111;
  }

  .success-cap small {
    display: block;
    margin-top: 3px;
    color: #32dd80;
    font-size: 9px;
    text-transform: uppercase;
  }

  .success-dots {
    margin-top: 18px;
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  .success-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 0;
    padding: 0;
    background: #c7c7c7;
    cursor: pointer;
  }

  .success-dot.active {
    background: #32dd80;
  }

  @media (min-width: 901px) {
    .success-slide {
      flex: 0 0 calc((100% - 2 * var(--gap)) / 3);
      width: auto;
      min-width: 0;
    }
  }

  @media (max-width: 980px) {
    .success-card { min-height: 240px; }
    .success-play { width: 50px; height: 50px; }
    .success-cap strong { width: 122px; font-size: 11px; }
    .success-cap small { font-size: 8px; }
    .success-dot { width: 10px; height: 10px; }
  }
</style>
