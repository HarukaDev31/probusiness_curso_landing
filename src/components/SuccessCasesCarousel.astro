---
const cards = [
  { title: 'JHONNY — RACKS PARA TV', tag: 'CASO DE ÉXITO' },
  { title: 'CLIENTE TESTIMONIO', tag: 'CASO DE ÉXITO' },
  { title: 'CLIENTE TESTIMONIO', tag: 'CASO DE ÉXITO' },
];
---

<div class="success-peek">
  <div class="success-cards">
    {cards.map((c) => (
      <article class="success-card">
        <button class="success-play" type="button" aria-label={`Reproducir testimonio: ${c.title}`}>
          <img src="/figma/success/play.png" alt="" aria-hidden="true" />
        </button>
      </article>
    ))}
  </div>
  <div class="success-captions">
    {cards.map((c) => (
      <div class="success-cap"><strong>{c.title}</strong><small>{c.tag}</small></div>
    ))}
  </div>
</div>
<div class="success-dots" aria-hidden="true"><span></span><span class="active"></span><span></span></div>

<style>
  .success-peek { overflow: hidden; }
  .success-cards { margin-top: 30px; display: flex; gap: 14px; width: max-content; }
  .success-card { width: 214px; min-height: 338px; border-radius: 10px; background: #2b2b2b; display: grid; place-items: center; }
  .success-play { border: 0; background: transparent; width: 72px; height: 72px; }
  .success-play img { width: 100%; height: 100%; object-fit: contain; }
  .success-captions { margin-top: 12px; display: flex; gap: 14px; width: max-content; }
  .success-cap { text-align: center; }
  .success-cap strong { display: block; width: 214px; font-size: 15px; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .success-cap small { display: block; margin-top: 3px; color: #32dd80; font-size: 9px; text-transform: uppercase; }
  .success-dots { margin-top: 18px; display: flex; justify-content: center; gap: 8px; }
  .success-dots span { width: 12px; height: 12px; border-radius: 50%; background: #c7c7c7; }
  .success-dots .active { background: #32dd80; }
  @media (max-width: 980px) {
    .success-card { width: 122px; min-height: 206px; }
    .success-play { width: 50px; height: 50px; }
    .success-cap strong { width: 122px; font-size: 11px; }
    .success-cap small { font-size: 8px; }
    .success-dots span { width: 10px; height: 10px; }
  }
</style>
