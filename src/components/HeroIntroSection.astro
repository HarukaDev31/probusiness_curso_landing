---
import HeroCopyBlock from './HeroCopyBlock.astro';
---

<section class="offer-bar">
  <p class="offer-bar-content">
    <img src="/figma/fire-desktop.png" alt="" class="offer-bar-icon" width="20" height="20" />
    <span class="offer-bar-text">
      <strong>Oferta por tiempo limitado</strong>
      — Precio especial: S/ 380 (precio regular S/ 500). Inscríbete antes de que suba.
    </span>
  </p>
</section>

<section class="hero-shell">
  <header class="hero-nav">
    <img
      src="/figma/logo-probusiness-desktop.png"
      alt="probusiness"
      class="hero-logo"
      loading="lazy"
      
    />
    <a href="#registro" class="hero-btn-top">Inscribirme ahora</a>
  </header>
  <HeroCopyBlock />
</section>

<style>
  .offer-bar {
    padding: 2px 16px;
    text-align: center;
    background: linear-gradient(90deg, #00da80 0.43%, #111 120.37%);
    color: white;
    font-size: 16px;
    line-height: 1.4;
    font-family: "Sora", sans-serif;
  }
  .offer-bar-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .offer-bar strong {
    font-weight: 700;
  }
  .offer-bar-text {
    display: inline;
  }
  .hero-shell {
    width: 100%;
    margin: 0 auto;
    padding: 18px 0 0 0;
  }
  .hero-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    padding: 0 30px;
  }
  .hero-logo {
    width: 150px;
  }
  .hero-btn-top {
    font-size: 16px;
    border-radius: 8px;
    padding: 8px 12px;
    color: #041109;
    text-decoration: none;
    font-weight: 600;
    border-radius: 10px;
    border: 1px solid var(--Linear, #25cf43);
    background: linear-gradient(90deg, #32dd80 0%, #3fe088 100%);
  }
  @media (max-width: 980px) {
    /* Figma node 4100:225 — barra superior móvil */
    .offer-bar {
      padding: 8px 10px;
      font-size: 10px;
      line-height: 1.25;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      background: #00843d;
    }
    .offer-bar-content {
      flex-wrap: nowrap;
      justify-content: center;
      align-items: center;
      gap: 6px;
      max-width: 100%;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .offer-bar-icon {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
      object-fit: contain;
    }
    .hero-shell {
      padding: 10px 0 0;
    }
    .hero-nav {
      padding: 0 12px;
      justify-content: center;
      margin-bottom: 8px;
    }
    .hero-logo {
      width: min(122px, 36vw);
    }
    .hero-btn-top {
      display: none;
    }
  }
</style>
