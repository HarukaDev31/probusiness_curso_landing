---
import HeroCopyBlock from './HeroCopyBlock.astro';
---

<section class="offer-bar">
  <p class="offer-bar-content">
    <img src="/figma/fire-desktop.png" alt="oferta" class="offer-bar-icon" />
    <strong>OFERTA POR TIEMPO LIMITADO</strong> — PRECIO ESPECIAL: S/ 380 (PRECIO
    REGULAR S/ 500). INSCRÍBETE ANTES DE QUE SUBA.
  </p>
</section>

<section class="hero-shell">
  <header class="hero-nav">
    <img
      src="/figma/logo-probusiness-desktop.png"
      alt="probusiness"
      class="hero-logo"
      loading="lazy"
      
    />
    <a href="#registro" class="hero-btn-top">Inscribirme ahora</a>
  </header>
  <HeroCopyBlock />
</section>

<style>
  .offer-bar {
    padding: 2px 16px;
    text-align: center;
    background: linear-gradient(90deg, #00da80 0.43%, #111 120.37%);
    color: white;
    font-size: 16px;
    line-height: 1.4;
    font-family: "Sora", sans-serif;
  }
  .offer-bar-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .offer-bar strong {
    font-weight: 700;
  }
  .hero-shell {
    width: 100%;
    margin: 0 auto;
    padding: 18px 0 0 0;
  }
  .hero-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    padding: 0 30px;
  }
  .hero-logo {
    width: 150px;
  }
  .hero-btn-top {
    font-size: 16px;
    border-radius: 8px;
    padding: 8px 12px;
    color: #041109;
    text-decoration: none;
    font-weight: 600;
    border-radius: 10px;
    border: 1px solid var(--Linear, #25cf43);
    background: linear-gradient(90deg, #32dd80 0%, #3fe088 100%);
  }
  @media (max-width: 980px) {
    .offer-bar {
      padding: 14px 24px;
      font-size: 16px;
    }
    .hero-shell {
      padding: 34px 48px 40px;
    }
    .hero-logo {
      width: 250px;
    }
    .hero-btn-top {
      font-size: 36px;
      border-radius: 10px;
      padding: 14px 26px;
    }
  }
</style>
