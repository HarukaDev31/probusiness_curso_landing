---
const items = [
  { title: 'Oficina en China y Peru', icon: '/figma/support-grid/building.png' },
  { title: 'Lista de contactos', icon: '/figma/support-grid/contacts.png' },
  { title: 'Lista de proveedores', icon: '/figma/support-grid/providers.png' },
  { title: 'Ayuda importadora 1 año', icon: '/figma/support-grid/help.png' },
  { title: 'Aula virtual por 1 año', icon: '/figma/support-grid/virtual.png' },
  { title: 'Plantillas de trabajo', icon: '/figma/support-grid/briefcase.png' },
  { title: 'Conexión a carga consolidada', icon: '/figma/support-grid/consolidated.png' },
  { title: '10 años de experiencia', icon: '/figma/support-grid/ten.png' },
];
---
<section class="support-grid-section">
  <div class="support-grid-wrap">
    {items.map((item) => (
      <article class="support-card">
        <img src={item.icon} alt="" aria-hidden="true" />
        <p>{item.title}</p>
      </article>
    ))}
  </div>
</section>
<style>
  .support-grid-section { background: #fff; padding: 10px 0 44px; }
  .support-grid-wrap { width: min(100%, 1068px); margin: 0 auto; padding: 0 16px; display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; }
  .support-card { min-height: 160px; border-radius: 14px; background: #f6fff4; border: 1px solid rgba(0,0,0,.1); padding: 12px; display: flex; flex-direction: column; }
  .support-card img { width: 44px; height: 44px; object-fit: contain; margin-bottom: auto; }
  .support-card p { margin: 8px 0 0; color: #00a24a; font-family: 'Sora', sans-serif; font-size: 16px; line-height: 1.1; font-weight: 600; }
  @media (max-width: 980px) { .support-grid-wrap { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
</style>
