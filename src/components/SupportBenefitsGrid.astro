<style>
  .support-grid-section {
    background: #fff;
    padding: 56px 0 44px;
    position: relative;
  }

  .support-grid-deco {
    display: none;
    pointer-events: none;
  }

  .support-grid-heading {
    width: 80%;
    margin: 0 auto 34px;
    padding: 0 16px;
  }

  .support-grid-kicker {
    margin: 0 0 10px;
    font-family: "Sora", sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #32dd80;
  }

  .support-grid-title {
    margin: 0;
    font-family: "Epilogue", sans-serif;
    font-weight: 300;
    font-size: 64px;
    line-height: 1.14;
    letter-spacing: -3.84px;
    color: #111;
  }

  .support-grid-title-line {
    display: block;
  }

  .support-grid-title-accent {
    background: conic-gradient(
      from 180deg at 50% 50%,
      #32dd80 0deg,
      #000 308.0769181251526deg
    );
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: Epilogue;

    font-weight: 500;
    line-height: 90%;
    letter-spacing: -2.1px;
  }
  .support-grid-wrap {
    width: min(100%, 1068px);
    margin: 0 auto;
    padding: 0 16px;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .support-card {
    min-height: 140px;
    border-radius: 14px;
    background: #f6fff4;
    border: 1px solid rgba(0, 0, 0, 0.06);
    padding: 14px 14px 16px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .support-card-icon {
    width: 34px;
