---
type BenefitTone = "white" | "green";
type BenefitLinePart = { text: string; tone: BenefitTone };
type Benefit = {
  icon: string;
  lines: BenefitLinePart[][];
};

// Figma (node-id=4073:160) resalta ciertas palabras en verde y divide algunos textos en 2 líneas.
const benefits: Benefit[] = [
  {
    icon: "/figma/course-benefits/fi9573199.svg",
    lines: [
      [{ text: "Clases en", tone: "white" }],
      [{ text: "vivo", tone: "white" }],
    ],
  },
  {
    icon: "/figma/course-benefits/layer2.svg",
    lines: [
      [{ text: "2 semanas", tone: "green" }],
      [{ text: "de duración", tone: "white" }],
    ],
  },
  {
    icon: "/figma/course-benefits/fi17255146.svg",
    lines: [
      [
        { text: "Para ", tone: "white" },
        { text: "principiantes y", tone: "green" },
      ],
      [{ text: "con experiencia.", tone: "green" }],
    ],
  },
  {
    icon: "/figma/course-benefits/group.svg",
    lines: [
      [{ text: "Aula", tone: "white" }],
      [{ text: "virtual", tone: "white" }],
    ],
  },
  {
    icon: "/figma/course-benefits/fi87932.svg",
    lines: [[{ text: "Acompañamiento incluido", tone: "white" }]],
  },
  {
    icon: "/figma/course-benefits/fi4592936.svg",
    lines: [
      [{ text: "100%", tone: "green" }],
      [{ text: "practico y aplicable.", tone: "white" }],
    ],
  },
];
---

<section class="benefits">
  <div class="benefits-wrap">
    <!-- deco (se recorta con overflow:hidden en beneficios-wrap) -->
    <div class="benefits-deco-left"></div>
    <div class="benefits-deco-right"></div>
    {
      benefits.map((b) => (
        <article class="benefit">
          <img src={b.icon} alt="" aria-hidden="true" />
          <p class="benefit-text">
            {b.lines.map((line, idx) => (
              <>
                {idx > 0 ? <br /> : null}
                {line.map((part, partIdx) => (
                  <span
                    class={part.tone === "green" ? "tone-green" : "tone-white"}
                  >
                    {part.text}
                  </span>
                ))}
              </>
            ))}
          </p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .benefits {
    margin-top: 4em;
    background: #1a1a1a;
    padding: 0;
    position: relative;
    overflow: hidden; /* Recorte extra de decoraciones */
  }

  /* Coincide con el frame de Figma ~1152x220 */
  .benefits-wrap {
    width: 100%;
    margin: 0 auto;
    padding: 26px 16px;
    height: auto;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    position: relative;
    overflow: hidden; /* Recorte de decoraciones */
  }

  .benefits-deco-left {
    background: radial-gradient(
      46% 46% at 50% 50%,
      rgba(50, 221, 128, 0.59) 0%,
      rgba(50, 221, 128, 0) 100%
    );
    position: absolute;
    left: -200px;
    top: -250px;
    width: 400px;
    height: 400px;
    pointer-events: none;
    z-index: 0;
  }

  .benefits-deco-right {
    background: radial-gradient(
      46% 46% at 50% 50%,
      rgba(50, 221, 128, 0.59) 0%,
      rgba(50, 221, 128, 0) 100%
    );
    position: absolute;
    right: -200px;
    top: -250px;
    width: 400px;
    height: 400px;
    pointer-events: none;
    z-index: 0;
  }

  .benefit {
    flex: 1 1 0;
    text-align: center;
    color: #fff;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 0 8px;
    z-index: 1; /* Asegura que quede por encima de decoraciones */
  }

  /* Línea vertical separadora (dotted) */
  .benefit:not(:last-child)::after {
    content: "";
    position: absolute;
    right: 0;
    top: 8px;
    bottom: 12px;
    width: 1px;
    background-image: url("/figma/course-benefits/vector.svg");
    background-repeat: no-repeat;
    background-position: center;
    background-size: 1px 100%;
  }

  .benefit img {
    width: 42px;
    height: 42px;
    object-fit: contain;
    margin-bottom: 14px;
  }

  .benefit-text {
    margin: 0;
    font-size: 16px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 300;
  }

  .tone-green {
    color: #32dd80;
    font-weight: 300;
  }

  .tone-white {
    color: #fff;
    font-weight: 300;
  }

  @media (max-width: 980px) {
    .benefits-wrap {
      height: auto;
      padding: 18px 16px 34px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px 14px;
    }

    .benefits-deco-left,
    .benefits-deco-right {
      display: none;
    }

    .benefit {
      padding: 0;
    }

    .benefit:not(:last-child)::after {
      display: none;
    }
  }
</style>
