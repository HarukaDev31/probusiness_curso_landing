---
type BenefitTone = "white" | "green";
type BenefitLinePart = { text: string; tone: BenefitTone };
type Benefit = {
  icon: string;
  lines: BenefitLinePart[][];
};

// Figma (node-id=4073:160) resalta ciertas palabras en verde y divide algunos textos en 2 líneas.
const benefits: Benefit[] = [
  {
    icon: "/figma/course-benefits/fi9573199.svg",
    lines: [[{ text: "Clases en vivo", tone: "white" }]],
  },
  {
    icon: "/figma/course-benefits/layer2.svg",
    lines: [
      [{ text: "2 semanas", tone: "green" }],
      [{ text: "de duración", tone: "white" }],
    ],
  },
  {
    icon: "/figma/course-benefits/fi17255146.svg",
    lines: [
      [
        { text: "Para ", tone: "white" },
        { text: "principiantes y", tone: "green" },
      ],
      [{ text: "con experiencia.", tone: "white" }],
    ],
  },
  {
    icon: "/figma/course-benefits/group.svg",
    lines: [
      [{ text: "Aula", tone: "white" }],
      [{ text: "virtual", tone: "white" }],
    ],
  },
  {
    icon: "/figma/course-benefits/fi87932.svg",
    lines: [[{ text: "Acompañamiento incluido", tone: "white" }]],
  },
  {
    icon: "/figma/course-benefits/fi4592936.svg",
    lines: [
      [{ text: "100%", tone: "green" }],
      [{ text: "practico y aplicable.", tone: "white" }],
    ],
  },
];
---

<section class="benefits">
  <div class="benefits-deco-left" aria-hidden="true"></div>
  <div class="benefits-deco-right" aria-hidden="true"></div>
  <div class="benefits-wrap">
    {
      benefits.map((b) => (
        <article class="benefit">
          <img src={b.icon} alt="" aria-hidden="true" />
          <p class="benefit-text">
            {b.lines.map((line, idx) => (
              <>
                {idx > 0 ? <br /> : null}
                {line.map((part, partIdx) => (
                  <span
                    class={part.tone === "green" ? "tone-green" : "tone-white"}
                  >
                    {part.text}
                  </span>
                ))}
              </>
            ))}
          </p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .benefits {
    margin-top: 4em;
    background: #0b0b0b;
    padding: 0;
    position: relative;
    overflow: hidden; /* Recorte extra de decoraciones */
  }

  /* Coincide con el frame de Figma ~1152x220 */
  .benefits-wrap {
    width: 100%;
    margin: 0 auto;
    padding: 26px 16px;
    height: auto;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    position: relative;
    z-index: 1;
  }

  .benefits-deco-left {
    background: radial-gradient(
      46% 46% at 50% 50%,
      rgba(50, 221, 128, 0.59) 0%,
      rgba(50, 221, 128, 0) 100%
    );
    position: absolute;
    left: -200px;
    top: -250px;
    width: 400px;
    height: 400px;
    pointer-events: none;
    z-index: 0;
  }

  .benefits-deco-right {
    background: radial-gradient(
      46% 46% at 50% 50%,
      rgba(50, 221, 128, 0.59) 0%,
      rgba(50, 221, 128, 0) 100%
    );
    position: absolute;
    right: -200px;
    top: -250px;
    width: 400px;
    height: 400px;
    pointer-events: none;
    z-index: 0;
  }

  .benefit {
    flex: 1 1 0;
    text-align: center;
    color: #fff;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 0 8px;
    z-index: 1; /* Asegura que quede por encima de decoraciones */
  }

  /* Línea vertical separadora (dotted) */
  .benefit:not(:last-child)::after {
    content: "";
    position: absolute;
    right: 0;
    top: 8px;
    bottom: 12px;
    width: 1px;
    background-image: url("/figma/course-benefits/vector.svg");
    background-repeat: no-repeat;
    background-position: center;
    background-size: 1px 100%;
  }

  .benefit img {
    width: 42px;
    height: 42px;
    object-fit: contain;
    margin-bottom: 14px;
  }

  .benefit-text {
    margin: 0;
    font-size: 16px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 300;
  }

  .tone-green {
    color: #32dd80;
    font-weight: 300;
  }

  .tone-white {
    color: #fff;
    font-weight: 300;
  }

  @media (max-width: 980px) {
    /* Halos: izquierda ~fila central (bloque “principiantes”); derecha ~entre filas 3 y 4 */
    .benefits-deco-left,
    .benefits-deco-right {
      width: min(88vw, 380px);
      height: min(88vw, 380px);
      border-radius: 50%;
    }

    .benefits-deco-left {
      left: max(-42vw, -160px);
      top: 28%;
      transform: translateY(-40%);
      background: radial-gradient(
        50% 50% at 45% 50%,
        rgba(50, 221, 128, 0.42) 0%,
        rgba(50, 221, 128, 0.12) 38%,
        rgba(50, 221, 128, 0) 70%
      );
    }

    .benefits-deco-right {
      top: auto;
      right: max(-42vw, -160px);
      bottom: 6%;
      background: radial-gradient(
        50% 50% at 58% 42%,
        rgba(50, 221, 128, 0.4) 0%,
        rgba(50, 221, 128, 0.1) 40%,
        rgba(50, 221, 128, 0) 72%
      );
    }

    .benefits-wrap {
      height: auto;
      padding: 24px clamp(12px, 4vw, 20px) 40px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: repeat(4, auto);
      align-items: stretch;
      justify-items: stretch;
      gap: 0;
      border-top: 1px dotted rgba(255, 255, 255, 0.22);
    }

    /* 2 + 1 + 2 + 1 (captura móvil); filas explícitas para misma altura en columnas */
    .benefit:nth-child(1) {
      grid-column: 1;
      grid-row: 1;
      border-right: 1px dotted rgba(255, 255, 255, 0.22);
      border-bottom: 1px dotted rgba(255, 255, 255, 0.22);
    }
    .benefit:nth-child(2) {
      grid-column: 2;
      grid-row: 1;
      border-bottom: 1px dotted rgba(255, 255, 255, 0.22);
    }
    .benefit:nth-child(3) {
      grid-column: 1 / -1;
      grid-row: 2;
      border-bottom: 1px dotted rgba(255, 255, 255, 0.22);
    }
    .benefit:nth-child(4) {
      grid-column: 1;
      grid-row: 3;
      border-right: 1px dotted rgba(255, 255, 255, 0.22);
      border-bottom: 1px dotted rgba(255, 255, 255, 0.22);
    }
    .benefit:nth-child(5) {
      grid-column: 2;
      grid-row: 3;
      border-bottom: 1px dotted rgba(255, 255, 255, 0.22);
    }
    .benefit:nth-child(6) {
      grid-column: 1 / -1;
      grid-row: 4;
    }

    .benefit {
      flex: none;
      align-self: stretch;
      justify-self: stretch;
      width: 100%;
      box-sizing: border-box;
      padding: 20px 12px 22px;
      justify-content: center;
    }

    .benefit:not(:last-child)::after {
      display: none;
    }

    .benefit-text {
      font-family: "Sora", sans-serif;
      font-size: clamp(13px, 3.45vw, 15px);
      line-height: 1.18;
      letter-spacing: -0.01em;
    }

    .benefit img {
      width: 44px;
      height: 44px;
      margin-bottom: 14px;
    }

    .tone-white {
      color: #f0f0f0;
    }
  }
</style>
