---
const benefits = [
  { icon: '/figma/features/icon-video.png', title: 'Clases en vivo' },
  { icon: '/figma/features/icon-clock.png', title: '2 semanas de duración' },
  { icon: '/figma/features/icon-users.png', title: 'Para principiantes y con experiencia' },
  { icon: '/figma/features/icon-aula.png', title: 'Aula virtual' },
  { icon: '/figma/features/icon-check.png', title: 'Acompañamiento incluido' },
  { icon: '/figma/features/icon-like.png', title: '100% práctico y aplicable' },
];
---

<section class="benefits">
  <div class="benefits-wrap">
    {benefits.map((b) => (
      <article class="benefit">
        <img src={b.icon} alt="" aria-hidden="true" />
        <p>{b.title}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .benefits { background: #000; padding: 18px 0 34px; }
  .benefits-wrap { width: min(100%, 1180px); margin: 0 auto; padding: 0 16px; display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 12px; }
  .benefit { text-align: center; color: #fff; }
  .benefit img { width: 42px; height: 42px; object-fit: contain; margin-bottom: 8px; }
  .benefit p { margin: 0; font-size: 14px; line-height: 1.2; }
  @media (max-width: 980px) { .benefits-wrap { grid-template-columns: repeat(2, minmax(0,1fr)); gap: 14px; } }
</style>
